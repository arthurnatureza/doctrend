# .env.example — commite este arquivo no Git
# Copie para .env e preencha com seus valores reais.
# O arquivo .env NUNCA deve ser commitado (esta no .gitignore).

# ─── YouTube ─────────────────────────────────────────────────────────────────
# Chave da YouTube Data API v3. Obtenha em: https://console.developers.google.com/
# Sem chave, so funciona modo_demo (ver config/canais.yaml).
YOUTUBE_API_KEY=

# ─── Pipeline ────────────────────────────────────────────────────────────────
# Data de inicio da carga historica (formato YYYY-MM-DD)
HISTORICAL_START_DATE=2026-07-01

# ─── Ambiente ────────────────────────────────────────────────────────────────
# development ou production
ENVIRONMENT=development

# ─── Notificacao Telegram (opcional) ────────────────────────────────────────
# Deixe em branco para desativar. Sem os dois preenchidos, o pipeline roda
# normalmente e so pula o envio de notificacao.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Nota: a lista de canais do YouTube fica em
# api/doctrend_ingestor/config/canais.yaml (versionado no Git).
# Adicione ou remova canais via PR normalmente.
